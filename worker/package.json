{
  "name": "tbb-api-worker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "deploy:api": "wrangler deploy -c wrangler.api.toml",
    "db:migrate": "wrangler d1 execute tbb-db --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute tbb-db --remote --file=./schema.sql",
    "db:seed": "node scripts/seed-admin.mjs --local",
    "db:seed:remote": "node scripts/seed-admin.mjs --remote"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250224.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.14.0"
  }
}
