# Copy to .env and adjust for your MySQL instance.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=tbb_website

# Dev/same-origin proxy: leave off or false. Use true behind HTTPS only.
SESSION_COOKIE_SECURE=false

# Match vite.config.ts proxy target (php -S uses this port).
API_PORT=3001

# Admin login upsert — after applying database/schema.sql, run: npm run db:seed
# The PHP API also inserts this user once if the admins table is empty.
ADMIN_EMAIL=barbell@ballerina.com
ADMIN_PASSWORD=Admin123

# -----------------------------------------------------------------------------
# Klaviyo — welcome email for new early-access signups only
# -----------------------------------------------------------------------------
# Private API key: grant at least Profiles, Lists (for subscribe job), and Events (events:write).
# Audience → Lists → create "Early Access" (or use existing) → copy List ID from URL (?listId=...)
#
# Welcome email (recommended):
# Flows → Create flow → trigger "Metric" → search for metric **Early Access Signup**
# (fires after signup; first event may create this metric name in Klaviyo)
# → add Email action with your template.
# Do NOT also trigger a duplicate welcome on "Subscribed to list" unless you want two emails.
#
# List signup still runs for segmentation and consent via the bulk subscribe API.
#
# KLAVIYO_PRIVATE_API_KEY=pk_...
# KLAVIYO_EARLY_ACCESS_LIST_ID=AbC123
#
# Optional — API revision date header (defaults to 2025-04-15 if unset).
# KLAVIYO_API_REVISION=2025-04-15
